---
import CalendarIcon from "../icons/calendarIcon.astro";
import Counter from "../Counter.astro";
---

<section class="bg-[#1C1E1B] h-dvh overflow-hidden p-12 lg:p-0">
  <div
    class="text-white container mx-auto flex flex-col items-center justify-end h-[80%] px-6 font-serif"
  >
    <div class="text-center mb-24 md:mb-32 lg:mb-40">
      <p class="italic text-lg lg:text-xl 2xl:text-2xl">Brenda y Carlos</p>
      <p class="font-bold text-5xl lg:text-6xl 2xl:text-7xl">¡Nos casamos!</p>
    </div>
  </div>
  <div class="text-center bg-[#F9F1E6] semicircle p-7">
    <CalendarIcon class="size-6 mx-auto" />
    <p class="text-lg font-bold font-serif lg:text-xl">9 de Enero</p>
    <p class="text-xs lg:text-sm mb-2 font-serif">AGENDÁ LA FECHA</p>

    <Counter />

    <a href="#" class="bg-[#360D13] font-serif text-white rounded-full px-3 py-1 text-sm z-10 lg:text-base">
      AGENDAR FECHA
    </a>
  </div>
</section>

<style>
  .semicircle {
    aspect-ratio: 8 / 6;
    width: 140%;
    transform: translateY(-6%) translateX(-14.4%);
    border-radius: 50% 50% 0 0;
    margin: 0 auto;
  }
</style>
